#!/usr/bin/env bash
set -euo pipefail

release_id=${1:-}
expected_checksum=${2:-}
incoming_root=/var/lib/mserp-deploy/incoming
release_root=/opt/mserp/releases
current_link=/opt/mserp/current
backup_root=/var/backups/mserp

if [[ ! $release_id =~ ^[0-9a-f]{40}$ ]]; then
    echo "release id must be a 40-character lowercase Git commit SHA" >&2
    exit 2
fi
if [[ ! $expected_checksum =~ ^[0-9a-f]{64}$ ]]; then
    echo "checksum must be a lowercase SHA-256 digest" >&2
    exit 2
fi

exec 9>/run/lock/mserp-deploy.lock
if ! flock -n 9; then
    echo "another MSERP deployment is already running" >&2
    exit 1
fi

incoming_archive=$incoming_root/$release_id.tar.gz
release_dir=$release_root/$release_id
staged_archive=
extract_dir=

cleanup() {
    if [[ -n $staged_archive && -f $staged_archive ]]; then
        rm -f -- "$staged_archive"
    fi
    if [[ -n $extract_dir && -d $extract_dir ]]; then
        case $extract_dir in
            "$release_root"/.extract-*) rm -rf -- "$extract_dir" ;;
        esac
    fi
}
trap cleanup EXIT

if [[ ! -f $incoming_archive || -L $incoming_archive ]]; then
    echo "uploaded release archive is missing or invalid" >&2
    exit 1
fi

if [[ -d $release_dir ]]; then
    if [[ $(readlink -f "$current_link" 2>/dev/null || true) == "$release_dir" ]]; then
        curl --fail --silent --show-error http://127.0.0.1:18080/readyz >/dev/null
        rm -f -- "$incoming_archive"
        echo "release $release_id is already active"
        exit 0
    fi
    echo "release directory already exists but is not active" >&2
    exit 1
fi

staged_archive=$(mktemp /var/lib/mserp-deploy/.mserp-release.XXXXXX.tar.gz)
install -o root -g root -m 0600 "$incoming_archive" "$staged_archive"
echo "$expected_checksum  $staged_archive" | sha256sum --check --status

if tar -tzf "$staged_archive" | grep -Eq '(^/|(^|/)\.\.(/|$))'; then
    echo "release archive contains an unsafe path" >&2
    exit 1
fi
if tar -tvzf "$staged_archive" | awk '$1 !~ /^[-d]/ { found=1 } END { exit !found }'; then
    echo "release archive contains links or special files" >&2
    exit 1
fi

extract_dir=$(mktemp -d "$release_root/.extract-$release_id.XXXXXX")
tar -xzf "$staged_archive" -C "$extract_dir" --no-same-owner --no-same-permissions

if [[ ! -f $extract_dir/backend/mserp-api || ! -f $extract_dir/frontend/login.html || ! -d $extract_dir/migrations ]]; then
    echo "release archive does not contain the expected MSERP artifacts" >&2
    exit 1
fi

chown -R root:root "$extract_dir"
find "$extract_dir" -type d -exec chmod 0755 {} +
find "$extract_dir" -type f -exec chmod 0644 {} +
chown root:mserp "$extract_dir/backend/mserp-api"
chmod 0750 "$extract_dir/backend/mserp-api"
mv "$extract_dir" "$release_dir"
extract_dir=

install -d -o root -g root -m 0700 "$backup_root"
backup_file=$backup_root/mserp-$(date -u +%Y%m%dT%H%M%SZ)-$release_id.dump
install -o root -g root -m 0600 /dev/null "$backup_file"
runuser -u postgres -- pg_dump --format=custom --no-owner --no-acl --dbname=mserp > "$backup_file"

runuser -u postgres -- psql -X -v ON_ERROR_STOP=1 --dbname=mserp <<'SQL'
CREATE TABLE IF NOT EXISTS schema_migrations (
    version TEXT PRIMARY KEY,
    applied_at TIMESTAMPTZ NOT NULL DEFAULT now()
);
SQL

shopt -s nullglob
migrations=("$release_dir"/migrations/[0-9][0-9][0-9]_*.sql)
for migration in "${migrations[@]}"; do
    migration_name=$(basename "$migration")
	if [[ ! $migration_name =~ ^[0-9]{3}_[a-z0-9_]+\.sql$ ]]; then
		echo "invalid migration filename: $migration_name" >&2
		exit 1
	fi
	applied=$(printf "SELECT 1 FROM schema_migrations WHERE version = :'migration';\n" | \
		runuser -u postgres -- psql -X -At -v migration="$migration_name" --dbname=mserp)
    if [[ $applied == 1 ]]; then
        continue
    fi
    echo "applying migration $migration_name"
    runuser -u postgres -- psql -X -v ON_ERROR_STOP=1 --dbname=mserp --file="$migration"
	printf "INSERT INTO schema_migrations (version) VALUES (:'migration');\n" | \
		runuser -u postgres -- psql -X -v ON_ERROR_STOP=1 -v migration="$migration_name" --dbname=mserp
done

previous_release=$(readlink -f "$current_link" 2>/dev/null || true)
activate_release() {
    local target=$1
	ln -sfnT "$target" "$current_link.new"
    mv -Tf "$current_link.new" "$current_link"
}

activate_release "$release_dir"
if ! nginx -t || ! systemctl restart mserp-api.service || ! systemctl reload nginx; then
    if [[ -n $previous_release && -d $previous_release ]]; then
        activate_release "$previous_release"
        systemctl restart mserp-api.service
        systemctl reload nginx
    fi
    echo "release activation failed; application rolled back" >&2
    exit 1
fi

healthy=false
for _ in {1..15}; do
    if curl --fail --silent http://127.0.0.1:18080/readyz >/dev/null &&
        curl --insecure --fail --silent https://127.0.0.1:8443/login >/dev/null; then
        healthy=true
        break
    fi
    sleep 1
done

if [[ $healthy != true ]]; then
    if [[ -n $previous_release && -d $previous_release ]]; then
        activate_release "$previous_release"
        systemctl restart mserp-api.service
        systemctl reload nginx
    fi
    echo "release health check failed; application rolled back" >&2
    exit 1
fi

rm -f -- "$incoming_archive"
logger --tag mserp-deploy "activated release $release_id with backup $backup_file"
echo "activated MSERP release $release_id"
